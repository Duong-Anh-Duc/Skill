DATABASE_URL="postgresql://postgres:postgres@localhost:5432/google_oauth_service?schema=public"
PORT=3002

# Google OAuth2
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3002/api/oauth/callback"

# Frontend URL (redirect after OAuth callback)
APP_URL="http://localhost:5173"
